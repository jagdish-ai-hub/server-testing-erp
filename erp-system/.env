# Database
DB_USER=erpuser
DB_PASSWORD=erppassword
DB_NAME=erpdatabase

# JWT
JWT_SECRET=change-this-to-a-long-random-string-in-production

# Backup — Backblaze B2 (recommended) or AWS S3
# Leave S3_BUCKET empty to keep backups local only
S3_BUCKET=
S3_ENDPOINT_URL=https://s3.us-west-004.backblazeb2.com
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
